# Cerebras API
LLM_API_KEY=your-cerebras-api-key-here
CEREBRAS_MODEL=llama3.1-8b

# Global fallback system prompt — used only if Go does not send system_prompt in the request.
# Per-account prompts are stored in the DB and passed by Go on every request.
SYSTEM_PROMPT=You are a helpful assistant. Reply concisely.

# Server
HOST=0.0.0.0
PORT=8000